{
  "name": "versatile-thermostat-ui-card",
  "version": "0.5.0",
  "description": "Lovelace versatile-thermostat-ui",
  "keywords": [
    "home-assistant",
    "homeassistant",
    "hass",
    "automation",
    "lovelace",
    "custom-cards",
    "versatile-thermostat",
    "versatile_thermostat"
  ],
  "module": "versatile-thermostat-ui-card.js",
  "repository": "https://github.com/jmcollin78/versatile-thermostat-ui-card",
  "author": "Jean-Marc Collin",
  "type": "module",
  "scripts": {
    "start": "rollup -c --watch",
    "build": "rollup -c",
    "format": "prettier --write .",
    "start:hass": "docker run --rm -p8123:8123 -v ${PWD}/.hass_dev:/config homeassistant/home-assistant:beta",
    "start:hass-cmd": "docker run --rm -p8123:8123 -v  %cd%/.hass_dev:/config homeassistant/home-assistant:beta"
  },
  "dependencies": {
    "@egjs/hammerjs": "^2.0.17",
    "@mdi/js": "^7.4.47",
    "chart.js": "^4.5.1",
    "chartjs-adapter-date-fns": "^3.0.0",
    "chartjs-plugin-zoom": "^2.2.0",
    "date-fns": "^3.6.0",
    "home-assistant-js-websocket": "^9.6.0",
    "lit": "^3.3.2",
    "memoize-one": "^6.0.0",
    "superstruct": "^1.0.4"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-typescript": "^7.28.5",
    "@material/mwc-ripple": "^0.27.0",
    "@rollup/plugin-babel": "^7.0.0",
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/node": "^20.19.39",
    "prettier": "^3.8.3",
    "rollup": "4.60.2",
    "rollup-plugin-import-css": "^4.2.1",
    "rollup-plugin-minify-html-literals-v3": "^1.3.4",
    "rollup-plugin-serve": "^3.0.0",
    "@rollup/plugin-terser": "^1.0.0",
    "typescript": "^5.9.3"
  }
}